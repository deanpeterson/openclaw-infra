# Minimal layer on top of existing OpenClaw image — adds the Claude Code Bridge extension.
# Use the full Dockerfile for a complete rebuild; use this for fast iteration.
FROM quay.io/aicatalyst/openclaw:latest

USER 0

# Remove ALL dist extensions except our bridge and self-contained ones.
# The bundled dist extensions have broken ../../ imports that fail validation.
# Keep only directories that DON'T have ../../ imports in their JS files.
RUN for ext in /app/dist/extensions/*/; do \
      name=$(basename "$ext"); \
      [ "$name" = "claude-code-bridge" ] && continue; \
      if find "$ext" -name "*.js" -exec grep -l 'from "\.\./' {} + >/dev/null 2>&1; then \
        rm -rf "$ext"; \
      elif [ ! -f "$ext/index.js" ] && [ ! -f "$ext/index.ts" ]; then \
        rm -rf "$ext"; \
      fi; \
    done

# Install Claude Code CLI and esbuild for restoring stock TS-only plugins
RUN npm install -g @anthropic-ai/claude-code esbuild

# Create OAuth token well-known path (Claude CLI reads from here)
RUN mkdir -p /home/claude/.claude/remote && \
    chown -R node:0 /home/claude && \
    chmod -R g=u /home/claude

# Add Claude Code Bridge extension to both source and dist paths
COPY --chown=node:0 extensions/claude-code-bridge /app/extensions/claude-code-bridge
COPY --chown=node:0 extensions/claude-code-bridge /app/dist/extensions/claude-code-bridge
RUN chmod 755 /app/extensions/claude-code-bridge /app/dist/extensions/claude-code-bridge && \
    chmod 644 /app/extensions/claude-code-bridge/* /app/dist/extensions/claude-code-bridge/*

# Restore the upstream Discord channel plugin into the dist extension root.
# Our bridge-layer image prunes /app/dist/extensions aggressively, but Discord
# in the base image only exists as source under /app/extensions/discord. The
# gateway loads stock plugins from /app/dist/extensions, so without these
# bundled entrypoints Discord never registers as a live channel provider even
# though the token and config are present.
RUN mkdir -p /app/dist/extensions/discord && \
    cp /app/extensions/discord/openclaw.plugin.json /app/dist/extensions/discord/openclaw.plugin.json && \
    cp /app/extensions/discord/package.json /app/dist/extensions/discord/package.json && \
    cp -a /app/extensions/discord/node_modules /app/dist/extensions/discord/node_modules && \
    esbuild $(find /app/extensions/discord -type f -name '*.ts' ! -path '*/node_modules/*' | tr '\n' ' ') \
      --platform=node \
      --format=esm \
      --outbase=/app/extensions/discord \
      --outdir=/app/dist/extensions/discord

# The transpiled Discord extension imports OpenClaw internals through the
# package name "openclaw/...". The upstream runtime layout resolves those via
# the app root, so mirror that package alias explicitly in node_modules.
RUN ln -sfn /app /app/node_modules/openclaw

# Patch the current upstream bundle so plugin tools preserve defaultProfiles.
# This keeps Claude bridge tools in the effective model tool policy instead of
# dropping their profile metadata during runtime normalization.
RUN node <<'EOF'
const fs = require("fs");
const path = require("path");

function patchFile(filePath, replacements) {
  let source = fs.readFileSync(filePath, "utf8");
  let changed = false;

  for (const [before, after] of replacements) {
    if (!source.includes(before)) {
      console.warn(`Skipping patch; expected snippet not found in ${filePath}`);
      continue;
    }
    source = source.replace(before, after);
    changed = true;
  }

  if (changed) {
    fs.writeFileSync(filePath, source);
  }
}

const distDir = "/app/dist";
const authProfiles = fs.readdirSync(distDir).find((name) => name.startsWith("auth-profiles-") && name.endsWith(".js"));
const gatewayCli = fs.readdirSync(distDir).find((name) => name.startsWith("gateway-cli-") && name.endsWith(".js"));

if (!authProfiles || !gatewayCli) {
  throw new Error("Unable to locate OpenClaw dist bundles to patch");
}

patchFile(path.join(distDir, authProfiles), [[
`			pluginToolMeta.set(tool, {
				pluginId: entry.pluginId,
				optional: entry.optional
			});`,
`			pluginToolMeta.set(tool, {
				pluginId: entry.pluginId,
				optional: entry.optional,
				defaultProfiles: Array.isArray(tool.defaultProfiles) ? [...tool.defaultProfiles] : []
			});`
]]);

patchFile(path.join(distDir, gatewayCli), [[
`			optional: meta?.optional,
			defaultProfiles: []`,
`			optional: meta?.optional,
			defaultProfiles: Array.isArray(tool.defaultProfiles) ? [...tool.defaultProfiles] : Array.isArray(meta?.defaultProfiles) ? [...meta.defaultProfiles] : []`
]]);
EOF

USER node

# Direct gateway start (no proxy entrypoint needed)
CMD ["node", "openclaw.mjs", "gateway", "--allow-unconfigured"]
